# Optionale — toolul functioneaza si fara ele, dar imbunatatesc acuratetea

# Google Safe Browsing API (gratuit, obtine de la console.cloud.google.com)
GOOGLE_SAFE_BROWSING_KEY=

# VirusTotal API (gratuit, obtine de la virustotal.com/gui/my-apikey)
VIRUSTOTAL_KEY=

# Port server (default 3000)
PORT=3000
